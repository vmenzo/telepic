PORT=8787
HOST=0.0.0.0
PUBLIC_URL=http://127.0.0.1:8787
DATA_DIR=./data
DATABASE_DRIVER=sqlite
DATABASE_FILE=./data/telepic.sqlite
STORAGE_DRIVER=local
S3_BUCKET=
S3_REGION=auto
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
S3_PREFIX=telepic
S3_FORCE_PATH_STYLE=true

# Required for admin UI and private API actions.
ADMIN_TOKEN=change-me-to-a-long-random-secret
ADMIN_TOKEN_HASH=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin-password
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=
ADMIN_SESSION_HOURS=168
ADMIN_SESSION_IDLE_MINUTES=30

# Set to true if anonymous users may upload through the API/Web UI.
PUBLIC_UPLOAD=false

# Optional Telegram integration.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=change-me-webhook-secret

# Comma-separated Telegram user IDs allowed to use the bot.
# Leave empty only for a private test bot you fully control.
TELEGRAM_ALLOWED_USER_IDS=

# Max upload size in bytes. Default: 10485760 (10 MiB).
MAX_UPLOAD_BYTES=10485760

# Max time for URL uploads to download remote images.
REMOTE_FETCH_TIMEOUT_MS=12000

# SVG files can execute active content in some contexts. Keep disabled unless uploaders are trusted.
ALLOW_SVG_UPLOADS=false
